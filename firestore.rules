rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    /* =====================================================
       AGILE AI UNIVERSITY
       FIRESTORE SECURITY RULES

       Version : 2.5.0
       Status  : ACTIVE

       Security Model
       -----------------------------------------------------
       • Firebase Authentication UID is identity authority
       • /users/{uid} is the RBAC profile authority
       • credentials is the credential authority
       • credential_id is the permanent credential-asset
         authority
       • learner_uid is optional until identity activation
       • learning_resources is the governed learning-resource
         metadata and publication registry
       • Protected learning-resource files remain in Storage
       • Learning-resource records are programme-scoped
       • Students may read only their own governed records
       • Students cannot directly read learning_resources
       • Admin users are currently bootstrap-authorized
         through the approved email list
       • Learning resources follow draft → published →
         withdrawn lifecycle
       • Learning-resource deletion is prohibited
       • All unlisted access is denied

       Change History
       -----------------------------------------------------
       v2.5.0
       • Added learning_resources registry
       • Added learning-resource contract validation
       • Added programme and document identity validation
       • Added delivery configuration validation
       • Added draft, publication and withdrawal lifecycle
       • Added authenticated administrator audit validation
       • Added published asset-authority preservation
       • Prohibited learner direct access
       • Prohibited client-side deletion
       • Preserved existing production collection rules

       v2.4.0
       • Established credential-first asset authority
       • Supported pre-activation credential assets
       • Preserved learner ownership during republication
       • Maintained default-deny access model
    ===================================================== */


    /* =====================================================
       AUTHENTICATION HELPERS
    ===================================================== */

    function isSignedIn() {

      return
        request.auth != null;

    }


    function isOwner(
      uid
    ) {

      return
        isSignedIn() &&
        request.auth.uid == uid;

    }


    function isBootstrapAdmin() {

      return
        isSignedIn() &&

        request.auth.token.email != null &&

        request.auth.token.email in [
          "dileep@agileai.university",
          "dileepav@gmail.com",
          "laau.aaiu@gmail.com"
        ];

    }


    /* =====================================================
       CREDENTIAL-ASSET HELPERS
    ===================================================== */

    function hasRequiredCredentialAssetFields(
      data
    ) {

      return
        "credential_id" in data &&
        data.credential_id is string &&
        data.credential_id.size() > 0 &&

        "asset_type" in data &&
        data.asset_type is string &&
        data.asset_type.size() > 0 &&

        "status" in data &&
        data.status == "published" &&

        "is_latest" in data &&
        data.is_latest == true &&

        "storage_path" in data &&
        data.storage_path is string &&
        data.storage_path.size() > 0 &&

        "download_url" in data &&
        data.download_url is string &&
        data.download_url.size() > 0;

    }


    function hasValidOptionalLearnerUid(
      data
    ) {

      return
        !("learner_uid" in data) ||
        data.learner_uid == null ||
        data.learner_uid is string;

    }


    function hasValidAssetType(
      data
    ) {

      return
        data.asset_type in [
          "university_certificate",
          "trainer_certificate",
          "digital_badge",
          "recognition_asset"
        ];

    }


    function preservesCredentialAssetIdentity() {

      return
        request.resource.data.credential_id ==
          resource.data.credential_id &&

        request.resource.data.asset_type ==
          resource.data.asset_type;

    }


    /* =====================================================
       LEARNING-RESOURCE HELPERS
    ===================================================== */

    function hasRequiredLearningResourceFields(
      data
    ) {

      return
        "resource_id" in data &&
        "program_code" in data &&
        "title" in data &&
        "description" in data &&
        "resource_type" in data &&
        "category" in data &&
        "delivery_type" in data &&

        "storage_path" in data &&
        "external_url" in data &&

        "file_name" in data &&
        "file_extension" in data &&
        "mime_type" in data &&
        "file_size" in data &&

        "preview_allowed" in data &&
        "download_allowed" in data &&
        "embed_allowed" in data &&

        "status" in data &&
        "is_active" in data &&
        "is_latest" in data &&

        "version" in data &&
        "display_order" in data &&

        "created_by_uid" in data &&
        "created_by_email" in data &&
        "created_at" in data &&

        "published_by_uid" in data &&
        "published_by_email" in data &&
        "published_at" in data &&

        "withdrawn_by_uid" in data &&
        "withdrawn_by_email" in data &&
        "withdrawn_at" in data &&
        "withdrawal_reason" in data &&

        "updated_at" in data &&
        "source" in data;

    }


    function hasValidLearningResourceDocumentId(
      documentId
    ) {

      /*
       * Canonical document ID:
       *
       * {resource-id}_v{version}
       *
       * Example:
       * aop-licensed-material_v1
       */

      return
        documentId.matches(
          '^[a-z0-9][a-z0-9-]{2,79}_v[1-9][0-9]*$'
        );

    }


    function hasValidLearningResourceIdentity(
      data
    ) {

      return
        data.resource_id is string &&

        data.resource_id.matches(
          '^[a-z0-9][a-z0-9-]{2,79}$'
        ) &&

        data.program_code is string &&

        data.program_code.matches(
          '^[A-Z0-9][A-Z0-9_-]{1,19}$'
        ) &&

        data.version is int &&
        data.version >= 1;

    }


    function hasValidLearningResourceText(
      data
    ) {

      return
        data.title is string &&
        data.title.size() > 0 &&
        data.title.size() <= 160 &&

        data.description is string &&
        data.description.size() <= 2000 &&

        data.withdrawal_reason is string &&
        data.withdrawal_reason.size() <= 1000;

    }


    function hasValidLearningResourceType(
      data
    ) {

      return
        data.resource_type in [
          "document",
          "image",
          "external_video",
          "external_link"
        ];

    }


    function hasValidLearningResourceCategory(
      data
    ) {

      return
        data.category in [
          "licensed_course_material",
          "supporting_document",
          "reference_material",
          "video",
          "download"
        ];

    }


    function hasValidLearningResourceDeliveryType(
      data
    ) {

      return
        data.delivery_type in [
          "protected_storage",
          "external_video",
          "external_link"
        ];

    }


    function hasValidNullableLearningResourceStrings(
      data
    ) {

      return
        (
          data.storage_path == null ||
          data.storage_path is string
        ) &&

        (
          data.external_url == null ||
          data.external_url is string
        ) &&

        (
          data.file_name == null ||
          data.file_name is string
        ) &&

        (
          data.file_extension == null ||
          data.file_extension is string
        ) &&

        (
          data.mime_type == null ||
          data.mime_type is string
        );

    }


    function hasValidLearningResourcePolicies(
      data
    ) {

      return
        data.preview_allowed is bool &&
        data.download_allowed is bool &&
        data.embed_allowed is bool;

    }


    function hasValidLearningResourcePresentation(
      data
    ) {

      return
        data.display_order is int &&
        data.display_order >= 0 &&
        data.display_order <= 10000 &&

        data.file_size is int &&
        data.file_size >= 0 &&
        data.file_size <= 52428800;

    }


    function hasValidLearningResourceStatus(
      data
    ) {

      return
        data.status in [
          "draft",
          "published",
          "withdrawn"
        ];

    }


    function hasConsistentLearningResourceState(
      data
    ) {

      return
        (
          data.status == "draft" &&
          data.is_active == false
        ) ||

        (
          data.status == "published" &&
          data.is_active == true
        ) ||

        (
          data.status == "withdrawn" &&
          data.is_active == false
        );

    }


    function hasValidLearningResourceFlags(
      data
    ) {

      return
        data.is_active is bool &&
        data.is_latest is bool &&

        hasConsistentLearningResourceState(
          data
        );

    }


    function hasValidHttpsExternalUrl(
      value
    ) {

      return
        value is string &&

        value.matches(
          '^https://[^ ]+$'
        );

    }


    function hasValidProtectedStoragePath(
      data
    ) {

      return
        data.storage_path is string &&

        data.storage_path.matches(
          '^learning-resources/[A-Z0-9][A-Z0-9_-]{1,19}/[a-z0-9][a-z0-9-]{2,79}/v[1-9][0-9]*/[A-Za-z0-9][A-Za-z0-9._-]{0,149}$'
        );

    }


    function hasValidPublishedDeliveryConfiguration(
      data
    ) {

      return
        (
          data.delivery_type ==
            "protected_storage" &&

          hasValidProtectedStoragePath(
            data
          ) &&

          (
            data.external_url == null ||
            data.external_url == ""
          ) &&

          data.file_name is string &&
          data.file_name.size() > 0 &&

          data.file_extension is string &&
          data.file_extension.size() > 0 &&

          data.mime_type is string &&
          data.mime_type.size() > 0 &&

          data.file_size > 0
        ) ||

        (
          data.delivery_type ==
            "external_video" &&

          hasValidHttpsExternalUrl(
            data.external_url
          ) &&

          (
            data.storage_path == null ||
            data.storage_path == ""
          ) &&

          data.download_allowed == false
        ) ||

        (
          data.delivery_type ==
            "external_link" &&

          hasValidHttpsExternalUrl(
            data.external_url
          ) &&

          (
            data.storage_path == null ||
            data.storage_path == ""
          )
        );

    }


    function hasValidLearningResourceDeliveryConfiguration(
      data
    ) {

      /*
       * Drafts may be saved before a file or external URL
       * has been supplied.
       *
       * Published and withdrawn records must retain a valid
       * delivery configuration.
       */

      return
        data.status == "draft" ||

        (
          data.status in [
            "published",
            "withdrawn"
          ] &&

          hasValidPublishedDeliveryConfiguration(
            data
          )
        );

    }


    function hasValidLearningResourceSource(
      data
    ) {

      return
        data.source ==
          "admin_portal";

    }


    function hasValidLearningResourceAuditTypes(
      data
    ) {

      return
        data.created_by_uid is string &&
        data.created_by_uid.size() > 0 &&

        data.created_by_email is string &&
        data.created_by_email.size() > 0 &&

        (
          data.published_by_uid == null ||
          data.published_by_uid is string
        ) &&

        (
          data.published_by_email == null ||
          data.published_by_email is string
        ) &&

        (
          data.published_at == null ||
          data.published_at is timestamp
        ) &&

        (
          data.withdrawn_by_uid == null ||
          data.withdrawn_by_uid is string
        ) &&

        (
          data.withdrawn_by_email == null ||
          data.withdrawn_by_email is string
        ) &&

        (
          data.withdrawn_at == null ||
          data.withdrawn_at is timestamp
        );

    }


    function hasValidLearningResourceContract(
      data
    ) {

      return
        hasRequiredLearningResourceFields(
          data
        ) &&

        hasValidLearningResourceIdentity(
          data
        ) &&

        hasValidLearningResourceText(
          data
        ) &&

        hasValidLearningResourceType(
          data
        ) &&

        hasValidLearningResourceCategory(
          data
        ) &&

        hasValidLearningResourceDeliveryType(
          data
        ) &&

        hasValidNullableLearningResourceStrings(
          data
        ) &&

        hasValidLearningResourcePolicies(
          data
        ) &&

        hasValidLearningResourcePresentation(
          data
        ) &&

        hasValidLearningResourceStatus(
          data
        ) &&

        hasValidLearningResourceFlags(
          data
        ) &&

        hasValidLearningResourceDeliveryConfiguration(
          data
        ) &&

        hasValidLearningResourceSource(
          data
        ) &&

        hasValidLearningResourceAuditTypes(
          data
        );

    }


    function isValidLearningResourceCreate(
      documentId
    ) {

      return
        hasValidLearningResourceDocumentId(
          documentId
        ) &&

        hasValidLearningResourceContract(
          request.resource.data
        ) &&

        request.resource.data.status ==
          "draft" &&

        request.resource.data.is_active ==
          false &&

        request.resource.data.is_latest ==
          true &&

        request.resource.data.created_by_uid ==
          request.auth.uid &&

        request.resource.data.created_by_email ==
          request.auth.token.email &&

        request.resource.data.created_at ==
          request.time &&

        request.resource.data.updated_at ==
          request.time &&

        request.resource.data.published_by_uid ==
          null &&

        request.resource.data.published_by_email ==
          null &&

        request.resource.data.published_at ==
          null &&

        request.resource.data.withdrawn_by_uid ==
          null &&

        request.resource.data.withdrawn_by_email ==
          null &&

        request.resource.data.withdrawn_at ==
          null &&

        request.resource.data.withdrawal_reason ==
          "";

    }


    function preservesLearningResourceIdentity() {

      return
        request.resource.data.resource_id ==
          resource.data.resource_id &&

        request.resource.data.program_code ==
          resource.data.program_code &&

        request.resource.data.version ==
          resource.data.version &&

        request.resource.data.source ==
          resource.data.source &&

        request.resource.data.created_by_uid ==
          resource.data.created_by_uid &&

        request.resource.data.created_by_email ==
          resource.data.created_by_email &&

        request.resource.data.created_at ==
          resource.data.created_at;

    }


    function hasValidLearningResourceTransition() {

      return
        (
          resource.data.status ==
            "draft" &&

          request.resource.data.status in [
            "draft",
            "published"
          ]
        ) ||

        (
          resource.data.status ==
            "published" &&

          request.resource.data.status in [
            "published",
            "withdrawn"
          ]
        );

    }


    function preservesPublishedLearningAssetAuthority() {

      return
        resource.data.status ==
          "draft" ||

        (
          request.resource.data.delivery_type ==
            resource.data.delivery_type &&

          request.resource.data.storage_path ==
            resource.data.storage_path &&

          request.resource.data.external_url ==
            resource.data.external_url &&

          request.resource.data.file_name ==
            resource.data.file_name &&

          request.resource.data.file_extension ==
            resource.data.file_extension &&

          request.resource.data.mime_type ==
            resource.data.mime_type &&

          request.resource.data.file_size ==
            resource.data.file_size
        );

    }


    function hasValidPublicationAudit() {

      return
        (
          request.resource.data.status ==
            "draft" &&

          request.resource.data.published_by_uid ==
            null &&

          request.resource.data.published_by_email ==
            null &&

          request.resource.data.published_at ==
            null
        ) ||

        (
          resource.data.status ==
            "draft" &&

          request.resource.data.status ==
            "published" &&

          request.resource.data.published_by_uid ==
            request.auth.uid &&

          request.resource.data.published_by_email ==
            request.auth.token.email &&

          request.resource.data.published_at ==
            request.time
        ) ||

        (
          resource.data.status ==
            "published" &&

          request.resource.data.published_by_uid ==
            resource.data.published_by_uid &&

          request.resource.data.published_by_email ==
            resource.data.published_by_email &&

          request.resource.data.published_at ==
            resource.data.published_at
        );

    }


    function hasValidWithdrawalAudit() {

      return
        (
          request.resource.data.status !=
            "withdrawn" &&

          request.resource.data.withdrawn_by_uid ==
            null &&

          request.resource.data.withdrawn_by_email ==
            null &&

          request.resource.data.withdrawn_at ==
            null &&

          request.resource.data.withdrawal_reason ==
            ""
        ) ||

        (
          resource.data.status ==
            "published" &&

          request.resource.data.status ==
            "withdrawn" &&

          request.resource.data.withdrawn_by_uid ==
            request.auth.uid &&

          request.resource.data.withdrawn_by_email ==
            request.auth.token.email &&

          request.resource.data.withdrawn_at ==
            request.time &&

          request.resource.data.withdrawal_reason is string &&

          request.resource.data.withdrawal_reason.size() >
            0
        );

    }


    function isValidLearningResourceUpdate() {

      return
        resource.data.status !=
          "withdrawn" &&

        hasValidLearningResourceContract(
          request.resource.data
        ) &&

        preservesLearningResourceIdentity() &&

        hasValidLearningResourceTransition() &&

        preservesPublishedLearningAssetAuthority() &&

        hasValidPublicationAudit() &&

        hasValidWithdrawalAudit() &&

        request.resource.data.updated_at ==
          request.time;

    }


    /* =====================================================
       USERS — RBAC PROFILE AUTHORITY
    ===================================================== */

    match /users/{uid} {

      allow get: if
        isOwner(
          uid
        ) ||
        isBootstrapAdmin();

      allow list: if
        isBootstrapAdmin();

      allow create, update, delete: if
        false;

    }


    /* =====================================================
       PUBLIC FAQ CONTENT
    ===================================================== */

    match /faqs/{docId} {

      allow read: if
        true;

      allow create, update, delete: if
        isBootstrapAdmin();

    }


    /* =====================================================
       CREDENTIALS — PUBLIC VERIFICATION
    ===================================================== */

    match /credentials/{docId} {

      allow get: if
        (
          resource.data.issued_status ==
            "finalized" &&

          (
            !(
              "approval_status" in resource.data
            ) ||

            resource.data.approval_status ==
              "approved"
          )
        ) ||

        (
          isSignedIn() &&

          "learner_uid" in resource.data &&

          resource.data.learner_uid ==
            request.auth.uid
        ) ||

        isBootstrapAdmin();

      allow list: if
        isSignedIn() ||
        isBootstrapAdmin();

      allow create, update, delete: if
        false;

    }


    /* =====================================================
       CREDENTIAL ASSETS — CREDENTIAL FIRST
    ===================================================== */

    match /credential_assets/{docId} {

      allow get, list: if
        (
          isSignedIn() &&

          "learner_uid" in resource.data &&

          resource.data.learner_uid !=
            null &&

          resource.data.learner_uid ==
            request.auth.uid &&

          resource.data.status ==
            "published" &&

          resource.data.is_latest ==
            true
        ) ||

        isBootstrapAdmin();

      allow create: if
        isBootstrapAdmin() &&

        hasRequiredCredentialAssetFields(
          request.resource.data
        ) &&

        hasValidOptionalLearnerUid(
          request.resource.data
        ) &&

        hasValidAssetType(
          request.resource.data
        );

      allow update: if
        isBootstrapAdmin() &&

        preservesCredentialAssetIdentity() &&

        hasRequiredCredentialAssetFields(
          request.resource.data
        ) &&

        hasValidOptionalLearnerUid(
          request.resource.data
        ) &&

        hasValidAssetType(
          request.resource.data
        );

      allow delete: if
        isBootstrapAdmin();

    }


    /* =====================================================
       LEARNING RESOURCES — ADMIN PUBLICATION AUTHORITY
    ===================================================== */

    match /learning_resources/{documentId} {

      /*
       * Direct client access is restricted to bootstrap
       * administrators.
       *
       * Learner delivery must flow through the future
       * authorized learning-resource access broker.
       */

      allow get, list: if
        isBootstrapAdmin();

      /*
       * New records must begin as governed drafts.
       */

      allow create: if
        isBootstrapAdmin() &&

        isValidLearningResourceCreate(
          documentId
        );

      /*
       * Permitted lifecycle:
       *
       * draft     → draft
       * draft     → published
       * published → published
       * published → withdrawn
       *
       * Withdrawn records are terminal.
       */

      allow update: if
        isBootstrapAdmin() &&

        isValidLearningResourceUpdate();

      /*
       * Physical metadata deletion is prohibited.
       * Withdrawal preserves audit and version history.
       */

      allow delete: if
        false;

    }


    /* =====================================================
       VERIFICATION REQUESTS — PUBLIC INTAKE
    ===================================================== */

    match /verification_requests/{docId} {

      allow create: if
        true;

      allow read, update, delete: if
        isBootstrapAdmin();

    }


    /* =====================================================
       EXECUTIVE ENTITLEMENTS
    ===================================================== */

    match /executiveEntitlements/{email} {

      allow get: if
        isSignedIn() &&
        request.auth.token.email ==
          email;

      allow list: if
        false;

      allow create, update, delete: if
        false;

    }


    /* =====================================================
       USER ENTITLEMENTS
    ===================================================== */

    match /user_entitlements/{uid} {

      allow get: if
        isOwner(
          uid
        ) ||
        isBootstrapAdmin();

      allow list: if
        isBootstrapAdmin();

      allow create, update, delete: if
        false;

    }


    /* =====================================================
       LEADS — ADMIN ONLY
    ===================================================== */

    match /leads/{docId} {

      allow read, write: if
        isBootstrapAdmin();

    }


    /* =====================================================
       LEAD COMMUNICATIONS — ADMIN ONLY
    ===================================================== */

    match /lead_communications/{docId} {

      allow read, write: if
        isBootstrapAdmin();

    }


    /* =====================================================
       BATCHES — ADMIN ONLY
    ===================================================== */

    match /batches/{docId} {

      allow read, write: if
        isBootstrapAdmin();

    }


    /* =====================================================
       TRAINER REGISTRY — ADMIN ONLY
    ===================================================== */

    match /trainerRegistry/{docId} {

      allow read, write: if
        isBootstrapAdmin();

    }


    /* =====================================================
       TRAINING ORGANIZATIONS — ADMIN ONLY
    ===================================================== */

    match /trainingOrganizations/{docId} {

      allow read, write: if
        isBootstrapAdmin();

    }


    /* =====================================================
       PROGRAMS — AUTHENTICATED READ
    ===================================================== */

    match /programs/{docId} {

      allow read: if
        isSignedIn() ||
        isBootstrapAdmin();

      allow create, update, delete: if
        isBootstrapAdmin();

    }


    /* =====================================================
       DEFAULT DENY
    ===================================================== */

    match /{document=**} {

      allow read, write: if
        false;

    }

  }

}