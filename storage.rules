rules_version = '2';

service firebase.storage {

  match /b/{bucket}/o {

    /* =====================================================
       AGILE AI UNIVERSITY
       CLOUD STORAGE SECURITY RULES

       Version : 1.3.0
       Status  : ACTIVE

       Security Model
       -----------------------------------------------------
       • Firebase Authentication is the identity authority
       • Bootstrap administrators are publication authorities
       • Admin Portal publishes credential assets
       • Admin Portal manages protected learning resources
       • Student Portal consumes governed resources only
       • Credential assets retain existing authenticated access
       • Licensed learning resources remain admin-only in Storage
       • Learning-resource files are immutable after upload
       • Replacement requires a new version path
       • Protected uploads must carry governed audit metadata
       • Storage metadata identity must match the object path
       • Client-side deletion is prohibited
       • All unspecified Storage access is denied

       Storage Domains
       -----------------------------------------------------
       credential-assets/
         Existing generated credential artifacts.

       learning-resources/
         Protected programme learning resources and licensed
         course materials.

       master-learning-resources/
         Protected master sources for learner-specific licensed
         course materials.

       Protected Learning Delivery
       -----------------------------------------------------
       Learners must not access protected learning-resource
       objects directly.

       A governed backend access broker must:
       • authenticate the learner;
       • verify the learner's programme entitlement;
       • verify resource publication state;
       • verify preview/download policy;
       • provide short-lived authorized access.

       Change History
       -----------------------------------------------------
       v1.3.0
       • Added protected master-learning-resources domain
       • Added physical Storage-domain metadata validation
       • Preserved admin-only read and create authority
       • Preserved immutable create-only object enforcement
       • Preserved default-deny learner access

       v1.2.0
       • Added Markdown learning-resource support
       • Added compatibility support for image/jpg
       • Added governed custom-metadata validation
       • Required upload metadata identity to match path identity
       • Required immutable-version and governance metadata
       • Required private no-store cache-control metadata
       • Preserved create-only immutable object enforcement
       • Preserved credential-assets production behaviour

       v1.1.0
       • Added protected learning-resources domain
       • Added programme-code validation
       • Added resource-ID validation
       • Added immutable version-path validation
       • Added safe filename validation
       • Added file-size validation
       • Added governed MIME-type validation
       • Restricted direct learning-resource reads to admins
       • Prohibited overwrite and deletion of learning resources
       • Preserved existing credential-assets behaviour

       v1.0.0
       • Established credential-assets security rules
       • Enabled authenticated credential-asset reads
       • Enabled bootstrap-admin asset publication
       • Prohibited client-side deletion
       • Established default-deny policy
    ===================================================== */


    /* =====================================================
       AUTHENTICATION HELPERS
    ===================================================== */

    function isSignedIn() {

      return
        request.auth != null;

    }


    function isBootstrapAdmin() {

      return
        isSignedIn() &&

        request.auth.token.email != null &&

        request.auth.token.email in [
          "dileep@agileai.university",
          "dileepav@gmail.com",
          "laau.aaiu@gmail.com"
        ];

    }


    /* =====================================================
       LEARNING-RESOURCE PATH HELPERS
    ===================================================== */

    function hasValidLearningProgramCode(
      programCode
    ) {

      return
        programCode is string &&

        programCode.matches(
          '^[A-Z0-9][A-Z0-9_-]{1,19}$'
        );

    }


    function hasValidLearningResourceId(
      resourceId
    ) {

      return
        resourceId is string &&

        resourceId.matches(
          '^[a-z0-9][a-z0-9-]{2,79}$'
        );

    }


    function hasValidLearningResourceVersion(
      version
    ) {

      return
        version is string &&

        version.matches(
          '^v[1-9][0-9]*$'
        );

    }


    function hasValidLearningResourceFileName(
      fileName
    ) {

      return
        fileName is string &&

        fileName.matches(
          '^[A-Za-z0-9][A-Za-z0-9._-]{0,149}$'
        );

    }


    /* =====================================================
       LEARNING-RESOURCE FILE HELPERS
    ===================================================== */

    function hasValidLearningResourceSize() {

      return
        request.resource.size > 0 &&

        request.resource.size <=
          50 * 1024 * 1024;

    }


    function hasValidLearningResourceContentType() {

      return
        request.resource.contentType != null &&

        request.resource.contentType in [
          "application/pdf",
          "text/plain",
          "text/markdown",
          "text/csv",
          "application/msword",
          "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
          "application/vnd.ms-powerpoint",
          "application/vnd.openxmlformats-officedocument.presentationml.presentation",
          "application/vnd.ms-excel",
          "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
          "application/vnd.oasis.opendocument.text",
          "application/vnd.oasis.opendocument.presentation",
          "application/vnd.oasis.opendocument.spreadsheet",
          "image/png",
          "image/jpeg",
          "image/jpg"
        ];

    }


    function hasValidLearningResourceCacheControl() {

      return
        request.resource.cacheControl ==
          "private,max-age=0,no-store";

    }


    /* =====================================================
       LEARNING-RESOURCE METADATA HELPERS
    ===================================================== */

    function hasRequiredLearningResourceMetadata() {

      return
        request.resource.metadata != null &&

        request.resource.metadata.program_code != null &&

        request.resource.metadata.resource_id != null &&

        request.resource.metadata.version != null &&

        request.resource.metadata.source != null &&

        request.resource.metadata.governance_domain != null &&

        request.resource.metadata.storage_domain != null &&

        request.resource.metadata.immutable_version != null &&

        request.resource.metadata.uploaded_by_uid != null &&

        request.resource.metadata.uploaded_by_email != null;

    }


    function hasValidLearningResourceMetadataTypes() {

      return
        request.resource.metadata.program_code is string &&

        request.resource.metadata.resource_id is string &&

        request.resource.metadata.version is string &&

        request.resource.metadata.source is string &&

        request.resource.metadata.governance_domain is string &&

        request.resource.metadata.storage_domain is string &&

        request.resource.metadata.immutable_version is string &&

        request.resource.metadata.uploaded_by_uid is string &&

        request.resource.metadata.uploaded_by_email is string;

    }


    function hasValidLearningResourceMetadataAuthority(
      storageDomain
    ) {

      return
        request.resource.metadata.source ==
          "admin_portal" &&

        request.resource.metadata.governance_domain ==
          "learning_resources" &&

        request.resource.metadata.storage_domain ==
          storageDomain &&

        request.resource.metadata.immutable_version ==
          "true" &&

        request.resource.metadata.uploaded_by_uid ==
          request.auth.uid &&

        request.resource.metadata.uploaded_by_email ==
          request.auth.token.email;

    }


    function learningResourceMetadataMatchesPath(
      programCode,
      resourceId,
      version
    ) {

      return
        request.resource.metadata.program_code ==
          programCode &&

        request.resource.metadata.resource_id ==
          resourceId &&

        version ==
          "v" + request.resource.metadata.version;

    }


    function hasValidLearningResourceMetadata(
      programCode,
      resourceId,
      version,
      storageDomain
    ) {

      return
        hasRequiredLearningResourceMetadata() &&

        hasValidLearningResourceMetadataTypes() &&

        hasValidLearningResourceMetadataAuthority(
          storageDomain
        ) &&

        learningResourceMetadataMatchesPath(
          programCode,
          resourceId,
          version
        );

    }


    /* =====================================================
       COMPLETE LEARNING-RESOURCE UPLOAD CONTRACT
    ===================================================== */

    function isValidLearningResourceUpload(
      programCode,
      resourceId,
      version,
      fileName,
      storageDomain
    ) {

      return
        hasValidLearningProgramCode(
          programCode
        ) &&

        hasValidLearningResourceId(
          resourceId
        ) &&

        hasValidLearningResourceVersion(
          version
        ) &&

        hasValidLearningResourceFileName(
          fileName
        ) &&

        hasValidLearningResourceSize() &&

        hasValidLearningResourceContentType() &&

        hasValidLearningResourceCacheControl() &&

        hasValidLearningResourceMetadata(
          programCode,
          resourceId,
          version,
          storageDomain
        );

    }

    /* =====================================================
       CREDENTIAL ASSETS
       EXISTING PRODUCTION BEHAVIOUR PRESERVED
    ===================================================== */

    match /credential-assets/{credentialId}/{allPaths=**} {

      /*
       * Authenticated learners and administrators may read
       * generated credential assets.
       *
       * Firestore credential_assets rules remain responsible
       * for governing which asset metadata a learner can
       * discover.
       */

      allow read: if
        isSignedIn();

      /*
       * Only approved bootstrap administrators may upload or
       * replace credential assets through the Admin Portal.
       *
       * Existing credential-generation behaviour is preserved.
       */

      allow create, update: if
        isBootstrapAdmin();

      /*
       * Credential asset deletion is intentionally disabled.
       *
       * Asset retirement must be handled through governed
       * metadata and versioning.
       */

      allow delete: if
        false;

    }


    /* =====================================================
       PROTECTED LEARNING RESOURCES

       Canonical Path
       -----------------------------------------------------
       learning-resources/
         {programCode}/
           {resourceId}/
             {version}/
               {fileName}
    ===================================================== */

    match /learning-resources/{programCode}/{resourceId}/{version}/{fileName} {

      /*
       * Direct reads remain restricted to approved
       * administrators. Learners use the authorized backend
       * delivery broker.
       */

      allow read: if
        isBootstrapAdmin();

      /*
       * Shared protected objects are create-only, validated,
       * private and immutable.
       */
      allow create: if
        isBootstrapAdmin() &&

        isValidLearningResourceUpload(
          programCode,
          resourceId,
          version,
          fileName,
          "learning_resources"
        );

      allow update: if
        false;

      allow delete: if
        false;

    }


    /* =====================================================
       PROTECTED MASTER LEARNING RESOURCES

       Canonical Path
       -----------------------------------------------------
       master-learning-resources/
         {programCode}/
           {resourceId}/
             {version}/
               {fileName}

       Master resources remain admin-only and immutable.
       Learners must never access master source files directly.
    ===================================================== */

    match /master-learning-resources/{programCode}/{resourceId}/{version}/{fileName} {

      allow read: if
        isBootstrapAdmin();

      allow create: if
        isBootstrapAdmin() &&

        isValidLearningResourceUpload(
          programCode,
          resourceId,
          version,
          fileName,
          "master_learning_resources"
        );

      allow update: if
        false;

      allow delete: if
        false;

    }


    /* =====================================================
       DEFAULT DENY
    ===================================================== */

    match /{allPaths=**} {

      allow read, write: if
        false;

    }

  }

}