rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    /* =====================================================
       AGILE AI UNIVERSITY
       FIRESTORE SECURITY RULES

       Version : 2.4.0
       Status  : ACTIVE

       Security Model
       -----------------------------------------------------
       • Firebase Authentication UID is identity authority
       • /users/{uid} is the RBAC profile authority
       • credentials is the credential authority
       • credential_id is the permanent credential-asset
         authority
       • learner_uid is optional until identity activation
       • Students may read only their own governed records
       • Admin users are currently bootstrap-authorized
         through the approved email list
       • All unlisted access is denied
    ===================================================== */


    /* =====================================================
       AUTHENTICATION HELPERS
    ===================================================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() &&
             request.auth.uid == uid;
    }

    function isBootstrapAdmin() {
      return isSignedIn() &&
        request.auth.token.email in [
          "dileep@agileai.university",
          "dileepav@gmail.com",
          "laau.aaiu@gmail.com"
        ];
    }


    /* =====================================================
       CREDENTIAL-ASSET HELPERS
    ===================================================== */

    function hasRequiredCredentialAssetFields(data) {
      return
        "credential_id" in data &&
        data.credential_id is string &&
        data.credential_id.size() > 0 &&

        "asset_type" in data &&
        data.asset_type is string &&
        data.asset_type.size() > 0 &&

        "status" in data &&
        data.status == "published" &&

        "is_latest" in data &&
        data.is_latest == true &&

        "storage_path" in data &&
        data.storage_path is string &&
        data.storage_path.size() > 0 &&

        "download_url" in data &&
        data.download_url is string &&
        data.download_url.size() > 0;
    }

    function hasValidOptionalLearnerUid(data) {
      return
        !("learner_uid" in data) ||
        data.learner_uid == null ||
        data.learner_uid is string;
    }

    function hasValidAssetType(data) {
      return
        data.asset_type in [
          "university_certificate",
          "trainer_certificate",
          "digital_badge",
          "recognition_asset"
        ];
    }

    function preservesCredentialAssetIdentity() {
      return
        request.resource.data.credential_id ==
          resource.data.credential_id &&

        request.resource.data.asset_type ==
          resource.data.asset_type;
    }


    /* =====================================================
       USERS — RBAC PROFILE AUTHORITY
    ===================================================== */

    match /users/{uid} {

      /*
       * A signed-in user may read only their own profile.
       * Bootstrap administrators may read all user profiles.
       */

      allow get: if
        isOwner(uid) ||
        isBootstrapAdmin();

      /*
       * Collection-wide user listing is restricted to admins.
       */

      allow list: if
        isBootstrapAdmin();

      /*
       * Client-side writes are disabled.
       * Profiles must be maintained through trusted admin or
       * backend workflows.
       */

      allow create, update, delete: if false;
    }


    /* =====================================================
       PUBLIC FAQ CONTENT
    ===================================================== */

    match /faqs/{docId} {

      allow read: if true;

      allow create, update, delete: if
        isBootstrapAdmin();
    }


    /* =====================================================
       CREDENTIALS — PUBLIC VERIFICATION
    ===================================================== */

    match /credentials/{docId} {

      /*
       * Public verification remains available only for
       * finalized and approved credentials.
       *
       * Students may also read their own credential where
       * learner_uid is present.
       */

      allow get: if
        (
          resource.data.issued_status == "finalized" &&
          (
            !("approval_status" in resource.data) ||
            resource.data.approval_status == "approved"
          )
        ) ||
        (
          isSignedIn() &&
          "learner_uid" in resource.data &&
          resource.data.learner_uid == request.auth.uid
        ) ||
        isBootstrapAdmin();

      /*
       * Queries must only be permitted when every possible
       * returned credential satisfies the rule.
       */

      allow list: if
        isSignedIn() ||
        isBootstrapAdmin();

      /*
       * Client-side credential writes remain disabled.
       * Credential ownership and lifecycle changes must flow
       * through governed backend services.
       */

      allow create, update, delete: if false;
    }


    /* =====================================================
       CREDENTIAL ASSETS — CREDENTIAL FIRST
    ===================================================== */

    match /credential_assets/{docId} {

      /*
       * Learners may read only published, latest assets that
       * are assigned to their authenticated Firebase UID.
       *
       * Historical assets may exist before activation with
       * learner_uid set to null. Those assets remain
       * inaccessible to learners until identity
       * reconciliation assigns ownership.
       */

      allow get, list: if
        (
          isSignedIn() &&

          "learner_uid" in resource.data &&
          resource.data.learner_uid != null &&
          resource.data.learner_uid ==
            request.auth.uid &&

          resource.data.status ==
            "published" &&

          resource.data.is_latest ==
            true
        ) ||
        isBootstrapAdmin();

      /*
       * Bootstrap administrators may publish asset metadata.
       *
       * credential_id is the permanent asset authority.
       * learner_uid may be null for historical credentials
       * that have not completed activation.
       */

      allow create: if
        isBootstrapAdmin() &&
        hasRequiredCredentialAssetFields(
          request.resource.data
        ) &&
        hasValidOptionalLearnerUid(
          request.resource.data
        ) &&
        hasValidAssetType(
          request.resource.data
        );

      /*
       * Bootstrap administrators may republish or update
       * asset metadata.
       *
       * The permanent credential and asset identity cannot
       * be changed through an update.
       */

      allow update: if
        isBootstrapAdmin() &&
        preservesCredentialAssetIdentity() &&
        hasRequiredCredentialAssetFields(
          request.resource.data
        ) &&
        hasValidOptionalLearnerUid(
          request.resource.data
        ) &&
        hasValidAssetType(
          request.resource.data
        );

      /*
       * Deletion remains an explicit administrator action.
       */

      allow delete: if
        isBootstrapAdmin();
    }


    /* =====================================================
       VERIFICATION REQUESTS — PUBLIC INTAKE
    ===================================================== */

    match /verification_requests/{docId} {

      allow create: if true;

      allow read, update, delete: if
        isBootstrapAdmin();
    }


    /* =====================================================
       EXECUTIVE ENTITLEMENTS
    ===================================================== */

    match /executiveEntitlements/{email} {

      allow get: if
        isSignedIn() &&
        request.auth.token.email == email;

      allow list: if false;

      allow create, update, delete: if false;
    }


    /* =====================================================
       USER ENTITLEMENTS
    ===================================================== */

    match /user_entitlements/{uid} {

      allow get: if
        isOwner(uid) ||
        isBootstrapAdmin();

      allow list: if
        isBootstrapAdmin();

      /*
       * Client-side entitlement writes remain disabled.
       * Entitlement assignment must occur through governed
       * backend services.
       */

      allow create, update, delete: if false;
    }


    /* =====================================================
       LEADS — ADMIN ONLY
    ===================================================== */

    match /leads/{docId} {

      allow read, write: if
        isBootstrapAdmin();
    }


    /* =====================================================
       LEAD COMMUNICATIONS — ADMIN ONLY
    ===================================================== */

    match /lead_communications/{docId} {

      allow read, write: if
        isBootstrapAdmin();
    }


    /* =====================================================
       BATCHES — ADMIN ONLY
    ===================================================== */

    match /batches/{docId} {

      allow read, write: if
        isBootstrapAdmin();
    }


    /* =====================================================
       TRAINER REGISTRY — ADMIN ONLY
    ===================================================== */

    match /trainerRegistry/{docId} {

      allow read, write: if
        isBootstrapAdmin();
    }


    /* =====================================================
       TRAINING ORGANIZATIONS — ADMIN ONLY
    ===================================================== */

    match /trainingOrganizations/{docId} {

      allow read, write: if
        isBootstrapAdmin();
    }


    /* =====================================================
       PROGRAMS — AUTHENTICATED READ
    ===================================================== */

    match /programs/{docId} {

      allow read: if
        isSignedIn() ||
        isBootstrapAdmin();

      allow create, update, delete: if
        isBootstrapAdmin();
    }


    /* =====================================================
       DEFAULT DENY
    ===================================================== */

    match /{document=**} {

      allow read, write: if false;
    }

  }

}